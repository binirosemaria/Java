pipeline {
    agent any

environment {
        DOCKER_IMAGE = "binirosemaria/myapp"
        DOCKER_TAG = "latest"
    }

    stages {
        stage('Git installation') {
            steps {
                //
sh 'sudo yum install git -y'
            }
        }
        stage('git clone') {
            steps {
                git branch: 'main', url: 'https://github.com/binirosemaria/Java.git'
            }
        }
        stage('Maven installation') {
            steps {
                sh 'sudo yum install maven -y'
            }
        }
stage('Build war') {
            steps {
                sh 'mvn clean package'
            }
        }
stage('docker Installation') {
            steps {
               sh ''' sudo yum install docker -y
                  sudo systemctl start docker
sudo systemctl enable docker
sudo usermod -aG docker jenkins
                ''' 
            }
        }
stage('docker') {
            steps {
sh '''
               docker build -t myapp:latest  .
'''

            }
        }

stage('Login to Docker Hub') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub-creds',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh """
                    echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin
                    """
                }
            }
        }


stage('Push Image') {
            steps {
                sh """
                docker tag myapp:latest binirosemaria/myapp:latest
                docker push $DOCKER_IMAGE:$DOCKER_TAG
                """
            }
        }

stage('Copy file to remote server') {
            steps {
                sshagent(['ssh-key-id']) {
                    sh '''
        
                        scp -o StrictHostKeyChecking=no manifest/*.yml ec2-user@172.31.36.197:/home/ec2-user/manifest/
                    '''
                }
            }
        }

stage('run the kubectl') {
            steps {
                sshagent(['ssh-key-id']) {
                    sh '''
			ssh -o StrictHostKeyChecking=no ec2-user@172.31.36.197 "cd /home/ec2-user/manifest/ && kubectl apply -f . && kubectl port-forward --address 0.0.0.0  svc/my-app-service 8080:8080"
                    '''
                }
            }
        }




    }
}
